{
  "name": "chronowhoop",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run --project unit",
    "test:browser": "vitest run --project browser",
    "test:browser-webkit": "vitest run --project browser-webkit",
    "test:all": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc -b && svelte-check --tsconfig ./tsconfig.app.json",
    "check": "bun run typecheck && bun run lint && bun run test && bun run build",
    "deploy": "bun run build && wrangler deploy"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^26.1.1",
    "@vitest/browser": "4.1.10",
    "@vitest/browser-playwright": "^4.1.10",
    "@webgpu/types": "^0.1.71",
    "eslint": "^10.7.0",
    "eslint-plugin-svelte": "^3.20.0",
    "globals": "^17.7.0",
    "playwright": "^1.61.1",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  }
}
